---
import { ArrowRight, BookOpen } from 'lucide-astro';
import { withBase } from '../lib/paths';

interface Link {
  label: string;
  href: string;
}

interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  description: string;
  primaryCta?: Link;
  secondaryCta?: Link;
  ctas?: Link[];
  image?: string;
}

const {
  eyebrow = 'Research lab',
  title,
  subtitle,
  description,
  primaryCta,
  secondaryCta,
  ctas,
  image = '/images/brand/cpil-hero-banner.png',
} = Astro.props;

const links = ctas ?? [primaryCta, secondaryCta].filter((link): link is Link => Boolean(link));
---

<section class="overflow-hidden border-b border-[rgba(var(--line),0.78)] bg-[rgb(var(--surface-raised))]">
  <div class="section-shell grid items-center gap-10 py-12 md:py-16 lg:grid-cols-[1.05fr_0.95fr]">
    <div class="max-w-3xl">
      <p class="inline-flex items-center gap-2 border-l-2 border-[rgb(var(--accent-strong))] pl-3 text-sm font-semibold uppercase tracking-[0.12em] text-[rgb(var(--muted))]">
        <BookOpen class="size-4 text-[rgb(var(--accent-strong))]" aria-hidden="true" />
        {eyebrow}
      </p>
      <h1 class="mt-6 max-w-4xl text-4xl font-bold leading-tight text-[rgb(var(--ink))] sm:text-5xl">
        {title}
      </h1>
      {
        subtitle && (
          <p class="mt-4 max-w-3xl text-2xl font-semibold leading-9 text-[rgb(var(--accent-strong))]">
            {subtitle}
          </p>
        )
      }
      <p class="mt-5 max-w-2xl text-base leading-8 text-[rgb(var(--muted))] sm:text-lg">
        {description}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        {
          links.map((link, index) => (
            <a
              href={withBase(link.href)}
              class:list={[
                'inline-flex min-h-11 items-center gap-2 rounded-md px-5 py-3 text-sm font-semibold no-underline transition',
                index === 0
                  ? 'bg-[rgb(var(--accent-strong))] text-white hover:bg-[rgb(var(--accent))]'
                  : 'border border-[rgba(var(--line),0.95)] bg-transparent text-[rgb(var(--ink))] hover:bg-[rgba(var(--line),0.25)]',
              ]}
            >
              {link.label}
              {index === 0 && <ArrowRight class="size-4" aria-hidden="true" />}
            </a>
          ))
        }
      </div>
    </div>

    <figure class="grid gap-4">
      <img
        src={withBase(image)}
        alt="Cyber-Physical Intelligence Lab banner with MBZUAI, McGill, Mila, and cyber-physical AI imagery"
        class="aspect-[16/9] w-full rounded-md border border-[rgba(var(--line),0.86)] object-cover"
        loading="eager"
        decoding="async"
      />
      <figcaption class="border-l border-[rgba(var(--line),0.95)] pl-4 text-sm leading-6 text-[rgb(var(--muted))]">
        Research at CPIL spans learning, reasoning, control, communication networks, and infrastructure-scale cyber-physical systems.
      </figcaption>
    </figure>
  </div>
</section>
