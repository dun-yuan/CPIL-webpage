---
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import { siteInfo } from '../data/site';
import { withBase } from '../lib/paths';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = `${siteInfo.shortName} | ${siteInfo.name}`,
  description = siteInfo.description,
  image = '/images/brand/cpil-affiliation-banner.png',
} = Astro.props;

const pageTitle = title.includes(siteInfo.shortName) ? title : `${title} | ${siteInfo.shortName}`;
const basePath = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL.replace(/\/$/, '');
const pathname = basePath && Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length) || '/'
  : Astro.url.pathname;
const canonical = new URL(withBase(pathname), Astro.site);
const ogImage = new URL(withBase(image), Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" href={withBase('/favicon.svg')} type="image/svg+xml" />
    <script is:inline>
      (() => {
        const storageKey = 'cpil-theme';
        const saved = localStorage.getItem(storageKey);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.classList.toggle('dark', theme === 'dark');
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body class="antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-[rgb(var(--surface-raised))] focus:px-4 focus:py-2 focus:text-sm focus:font-semibold focus:text-[rgb(var(--ink))] focus:shadow-lg"
    >
      Skip to content
    </a>
    <Navbar />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
